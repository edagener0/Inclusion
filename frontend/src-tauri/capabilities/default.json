{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://api.вашего-сервера.com/*"
        }
      ],
      "deny": [
        {
          "url": "https://private.вашего-сервера.com/*"
        }
      ]
    },
    "http:default"
  ]
}
